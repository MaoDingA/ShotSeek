# Never commit real values. Live mode reads these variables from the shell.
STEPFUN_API_KEY=
GOLDEN_AUDIO_URL=https://github.com/MaoDingA/ShotSeek/releases/download/m0-golden-audio-v1/golden.mp3

# Optional endpoint overrides. Files and async file ASR use the standard Open
# Platform channel; Chat Completions uses the Step Plan channel.
STEPFUN_FILES_BASE_URL=https://api.stepfun.com/v1
STEPFUN_CHAT_BASE_URL=https://api.stepfun.com/step_plan/v1
STEPFUN_ASR_BASE_URL=https://api.stepfun.com/v1
STEPFUN_SSE_ASR_BASE_URL=https://api.stepfun.com/step_plan/v1
STEPFUN_VISION_MODEL=step-3.7-flash
STEPFUN_ASR_MODEL=stepaudio-2.5-asr

# Query planning and verification remain local unless explicitly enabled.
SHOTSEEK_ALLOW_NETWORK=0
SHOTSEEK_HOST=127.0.0.1
SHOTSEEK_PORT=8000
